{
  "info": {
    "name": "FastAPI Job System",
    "_postman_id": "12345678-aaaa-bbbb-cccc-123456789012",
    "description": "JWT Auth + Background Job Processing API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sasi\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/register",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "8000",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sasi\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/auth/login",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "8000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"task_name\": \"process data\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/jobs/",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "8000",
              "path": ["jobs"]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/jobs/1",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "8000",
              "path": ["jobs", "1"]
            }
          }
        },
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/jobs/",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "8000",
              "path": ["jobs"]
            }
          }
        }
      ]
    }
  ]
}